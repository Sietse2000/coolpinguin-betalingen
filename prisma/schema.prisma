generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Upload {
  id               String        @id @default(cuid())
  filename         String
  fileType         FileType
  uploadedAt       DateTime      @default(now())
  transactionCount Int           @default(0)
  status           UploadStatus  @default(PROCESSING)
  // TTL: upload + tijdelijke transacties vervallen 2 uur na aanmaken
  expiresAt        DateTime?
  transactions     BankTransaction[]

  @@index([expiresAt])
}

model BankTransaction {
  id               String            @id @default(cuid())
  hash             String            @unique
  uploadId         String
  upload           Upload            @relation(fields: [uploadId], references: [id])
  bankReference    String?
  transactionDate  DateTime
  valueDate        DateTime?
  amount           Decimal           @db.Decimal(12, 2)
  currency         String            @default("EUR")
  creditDebit      CreditDebit
  counterpartyName String?
  counterpartyIban String?
  description      String?
  rawData          String            @db.Text
  status           TransactionStatus @default(PENDING)
  matchedInvoiceId String?
  confidence       Decimal?          @db.Decimal(4, 3)
  matchType        String?
  matchReason      String?
  duplicateReason  String?           // Reden waarom als duplicaat gemarkeerd
  // TTL: NULL = permanent (verwerkte betalingen), ingesteld = tijdelijk
  // Wordt op NULL gezet zodra status PROCESSED of PARTIAL_SUCCESS wordt
  expiresAt        DateTime?
  paymentLogs      PaymentLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
  @@index([transactionDate])
  @@index([amount])
  @@index([expiresAt])
}

// Cache van openstaande facturen uit RentMagic
model InvoiceCache {
  id           String    @id @default(cuid())
  invoiceId    String    @unique
  customerId   String?
  customerName String?
  totalAmount  Decimal   @db.Decimal(12, 2)
  openAmount   Decimal   @db.Decimal(12, 2)
  invoiceDate  DateTime?
  dueDate      DateTime?
  status       String?
  rawData      Json?
  syncedAt     DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([openAmount])
  @@index([customerName])
  @@index([invoiceId])
}

// Permanente log van elke RentMagic API-aanroep — nooit verwijderen
// Dit is de audit trail van wat er daadwerkelijk naar RentMagic gestuurd is
model PaymentLog {
  id                 String          @id @default(cuid())
  transactionId      String
  // onDelete: Cascade zodat cleanup van BankTransaction ook de PaymentLog meeneemt
  // voor niet-verwerkte transacties. Verwerkte transacties hebben expiresAt = null
  // dus die worden nooit gecleanup'd.
  transaction        BankTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  invoiceId          String
  amount             Decimal         @db.Decimal(12, 2)
  rentmagicPaymentId String?
  paymentStatus      LogStatus       @default(PENDING)
  labelStatus        LogStatus       @default(PENDING)
  paymentRequest     Json?
  paymentResponse    Json?
  labelRequest       Json?
  labelResponse      Json?
  errorMessage       String?
  retryCount         Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([transactionId])
  @@index([invoiceId])
}

// Audit trail van alle acties — permanent
model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  payload    Json?
  response   Json?
  success    Boolean
  errorMsg   String?
  createdAt  DateTime @default(now())

  @@index([entityId])
  @@index([entityType])
  @@index([createdAt])
}

enum FileType {
  CAMT053
  MT940
}

enum UploadStatus {
  PROCESSING
  DONE
  FAILED
}

enum CreditDebit {
  CRDT
  DBIT
}

enum TransactionStatus {
  PENDING
  AUTO_MATCHED
  REVIEW
  PROCESSED
  PARTIAL_SUCCESS
  REJECTED
  DUPLICATE
}

enum LogStatus {
  SUCCESS
  FAILED
  PENDING
  SKIPPED
}

// ─── Ritplanning ──────────────────────────────────────────────────────────────

// Opgeslagen Google OAuth token (singleton)
model GoogleToken {
  id           String   @id @default("singleton")
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Voertuigen/auto's
model Vehicle {
  id           String   @id @default(cuid())
  name         String
  licensePlate String?
  hasTrailer   Boolean  @default(false)
  isActive     Boolean  @default(true)
  routes       Route[]
  createdAt    DateTime @default(now())
}

// Een planningsdag
model PlanningDay {
  id        String         @id @default(cuid())
  date      DateTime       @db.Date
  status    PlanningStatus @default(DRAFT)
  routes    Route[]
  stops     Stop[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([date])
}

// Een rit voor één voertuig op een planningsdag
model Route {
  id            String      @id @default(cuid())
  planningDayId String
  planningDay   PlanningDay @relation(fields: [planningDayId], references: [id], onDelete: Cascade)
  vehicleId     String
  vehicle       Vehicle     @relation(fields: [vehicleId], references: [id])
  driverName    String?
  stops         Stop[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// Een stop (order of agenda-afspraak)
model Stop {
  id               String      @id @default(cuid())
  planningDayId    String
  planningDay      PlanningDay @relation(fields: [planningDayId], references: [id], onDelete: Cascade)
  routeId          String?
  route            Route?      @relation(fields: [routeId], references: [id], onDelete: SetNull)
  type             StopType
  // RentMagic order
  rentmagicOrderId String?
  customerName     String?
  address          String?
  // Google Calendar event
  calendarEventId  String?
  calendarTitle    String?
  calendarStart    DateTime?
  calendarEnd      DateTime?
  sortOrder        Int         @default(0)
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

// Opgeslagen weekplanning (JSON-blob per week)
// Slaat de volledige route-indeling op inclusief handmatige aanpassingen.
// knownSourceStops: stops uit RM/agenda bij laatste opslag — voor diff-detectie.
model RitplanningWeek {
  id               Int      @id @default(autoincrement())
  weekStart        String   @unique  // YYYY-MM-DD (eerste dag van het 7-daagse venster)
  updatedAt        DateTime @updatedAt
  routesJson       Json     // VehicleRoute[] met volledige stop-data
  knownSourceStops Json     // { id: string, date: string, name: string }[]

  @@index([weekStart])
}

// Vaste lijst van bezorgers — beheerd door de planner
model Driver {
  id                 String   @id @default(cuid())
  name               String   @unique
  isActive           Boolean  @default(true)
  damageFreeKm       Int      @default(0)  // huidige km-streak zonder schade
  rewardsEarned      Int      @default(0)  // aantal keer €100 beloning ontvangen
  welcomeBonusGiven  Boolean  @default(false)  // eenmalige welkomstbonus van 100km
  createdAt          DateTime @default(now())
}

// Log van gemelde en niet-gemelde schades per bezorger
model DamageReport {
  id          String   @id @default(cuid())
  driverName  String
  driverId    String?
  isReported  Boolean  // true = schade gemeld, false = schade niet gemeld
  kmAtTime    Int      // schadevrije km op het moment van de melding
  reportedBy  String?  // naam van de planner die het heeft ingevoerd
  note        String?
  date        String   // YYYY-MM-DD
  createdAt   DateTime @default(now())

  @@index([driverName])
  @@index([date])
}

// Dagregistratie per bezorger: wie reed welke auto, hoeveel km, hoeveel stops
model DriverSession {
  id             String   @id @default(cuid())
  date           String   // YYYY-MM-DD
  driverName     String
  vehicleName    String?
  vehicleId      String?
  kmDriven       Int?
  stopsCompleted Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([date, driverName])
  @@index([driverName])
  @@index([date])
}

// Status van een stop zoals gerapporteerd door de bezorger via de tablet
model StopTracking {
  id          String     @id @default(cuid())
  weekStart   String     // YYYY-MM-DD (verwijst naar RitplanningWeek.weekStart)
  vehicleId   String     // VehicleRoute.vehicleId
  stopKey     String     // rentmagicOrderId | calendarEventId | "manual:{vehicleId}:{date}:{idx}"
  status      StopStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  driverNote  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([weekStart, vehicleId, stopKey])
  @@index([weekStart])
}

enum StopStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum PlanningStatus {
  DRAFT
  CONFIRMED
}

enum StopType {
  PICKUP
  DELIVERY
  CALENDAR
}
